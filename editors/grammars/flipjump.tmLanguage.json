{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "FlipJump",
  "scopeName": "source.flipjump",
  "fileTypes": ["fj"],
  "patterns": [
    {
      "comment": "Strings first, so quoted content (e.g. \"def\") is never re-interpreted as code.",
      "name": "string.quoted.double.flipjump",
      "match": "\"([^\"\\\\]|\\\\.)*\""
    },
    {
      "name": "string.quoted.single.flipjump",
      "match": "'([^'\\\\]|\\\\.)*'"
    },
    {
      "comment": "Line continuation: a trailing backslash joins the next physical line.",
      "match": "\\\\$"
    },
    {
      "name": "comment.line.double-slash.flipjump",
      "match": "//.*$"
    },
    {
      "comment": "Macro call: an identifier at the start of a logical line that is not a language word, followed by args / a comment / EOL. Char-for-char port of the IDE's Monarch regex (see docs/_ext/fj_stl_extract/pygments_lexer.py).",
      "match": "(^[ \\t]*)((?!(?:def|ns|rep|pad|reserve|segment|wflip|dbit|dw|w)\\b)[A-Za-z_.][\\w.]*)(?=[ \\t]+[^;\\s/]|[ \\t]*(?://|$))",
      "captures": {
        "2": { "name": "entity.name.function.call.flipjump" }
      }
    },
    {
      "comment": "def NAME — macro declaration.",
      "match": "(\\bdef\\b)([ \\t]+)([A-Za-z_]\\w*)",
      "captures": {
        "1": { "name": "keyword.control.flipjump" },
        "3": { "name": "entity.name.function.flipjump" }
      }
    },
    {
      "comment": "ns NAME — namespace declaration.",
      "match": "(\\bns\\b)([ \\t]+)([A-Za-z_]\\w*)",
      "captures": {
        "1": { "name": "keyword.control.flipjump" },
        "3": { "name": "entity.name.namespace.flipjump" }
      }
    },
    {
      "match": "\\brep\\b",
      "name": "keyword.control.flipjump"
    },
    {
      "comment": "Constant: IDENT = expr. The (?!=) keeps `a == b` out.",
      "match": "([A-Za-z_]\\w*)([ \\t]*)(=)(?!=)",
      "captures": {
        "1": { "name": "variable.other.constant.flipjump" },
        "3": { "name": "keyword.operator.flipjump" }
      }
    },
    {
      "comment": "Label: IDENT: at the head of a statement. The (?!:) avoids a `::` digraph.",
      "match": "([A-Za-z_]\\w*)([ \\t]*)(:)(?!:)",
      "captures": {
        "1": { "name": "entity.name.label.flipjump" },
        "3": { "name": "punctuation.flipjump" }
      }
    },
    {
      "match": "\\b(pad|reserve|segment|wflip)\\b",
      "name": "keyword.other.directive.flipjump"
    },
    {
      "comment": "Well-known type-like names. NOT including `bit`, which the IDE colours as a plain identifier.",
      "match": "\\b(dbit|dw|w)\\b",
      "name": "support.type.flipjump"
    },
    {
      "comment": "Leading-dot identifiers (namespace navigation): .foo, ..tables.x",
      "match": "\\.{1,2}[A-Za-z_][\\w.]*",
      "name": "variable.other.member.flipjump"
    },
    {
      "comment": "Bare or dotted identifiers: stl.startup, bit, _local",
      "match": "[A-Za-z_][\\w.]*",
      "name": "variable.other.flipjump"
    },
    {
      "match": "0[xX][0-9a-fA-F]+",
      "name": "constant.numeric.hex.flipjump"
    },
    {
      "match": "0[bB][01]+",
      "name": "constant.numeric.binary.flipjump"
    },
    {
      "match": "\\d+",
      "name": "constant.numeric.integer.flipjump"
    },
    {
      "match": "[;,{}()\\[\\]]",
      "name": "punctuation.flipjump"
    },
    {
      "match": "[!=<>?@^|%&*+\\-/:#$]",
      "name": "keyword.operator.flipjump"
    }
  ]
}
